#. TRANSLATORS:
#. A message is displayed to warn the user that there is not enough space on
#. the boot partition.
msgid "Warning"
msgstr "경고"

#. TRANSLATORS:
#. A message is displayed to warn the user that there is not enough space on
#. the boot partition.
#, python-format
msgid "Not enough space on %s partition"
msgstr "%s 파티션 공간이 부족합니다."

#. TRANSLATORS:
#. The user can click the "Dismiss" button so that the warning will not be
#. displayed in the future.
msgid "Dismiss"
msgstr "해제"

#. TRANSLATORS:
#. The user can click the "Clean Up" button to start the cleanup program.
msgid "Clean Up"
msgstr "청소"

#. TRANSLATORS:
#. The autostart desktop name will be shown within 'Session and Startup'
#. (Autostart).
msgid "Cleanup Notifier"
msgstr "Cleanup 알림"

#. TRANSLATORS:
#. The autostart desktop entry comment will be shown within 'Session and
#. Startup' (Autostart).
msgid "Check available space at /boot"
msgstr "/boot 영역의 여유공간을 확인하세요."
