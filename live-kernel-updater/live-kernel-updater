my_exit() {
    local ret=${1:-0}

    pause exit $"Exit"

    #Msg "=> cleaning up"
    exit $ret
}

#------------------------------------------------------------------------------
# Trapped on exit.  Umount (order is vital!) remove the work_dir and remove
# the lock file.
#------------------------------------------------------------------------------
clean_up() {
    sync
    lib_clean_up
    # Only unmount USB_DIR if we mounted it ourselves; leave GIO/external mounts alone
    if [ "${LKU_DID_MOUNT:-true}" = true ]; then
        mp_cleanup $SQFS_DIR $USB_DIR $BIOS_DIR $WORK_DIR
    else
        mp_cleanup $SQFS_DIR $BIOS_DIR $WORK_DIR
    fi
    # toram: unmount LIVE_MP if we remounted it -- restore pre-lku state
    [ "$LKU_TORAM_MOUNT" = true ] && umount "$LIVE_MP" 2>/dev/null
    test -d $WORK_DIR && rmdir $WORK_DIR
    luks_close $LUKS_NAME
    unflock
}

