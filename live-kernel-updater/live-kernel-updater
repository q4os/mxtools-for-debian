# Override lib do_defrag: defrag kernels and initrds only -- skip .md5/.ver files
do_defrag() {
    local iso_dir=$1  prog=e4defrag  opts="-v"
    if ! which $prog &>/dev/null; then
        warn $"Could not find program %s.  Not defragmenting." $prog
        return
    fi
    local files
    files=$(find "${iso_dir%/}" -maxdepth 1 \
        \( -name "vmlinuz" -o -name "vmlinuz[0-9]" \
        -o -name "initrd.gz" -o -name "initrd[0-9].gz" \) 2>/dev/null)
    [ -n "$files" ] && cmd $prog $opts $files
}

